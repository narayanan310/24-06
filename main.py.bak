# ── Special commands that must never reach bus.publish ────────────────────────
_NO_DISPATCH_CMDS = {
    "SAFETY_ALERT",
    "UNKNOWN",
    "STATUS_QUERY",
    "MACRO_RESET",
    "RAG_RESPONSE",
    "INCOMPLETE_COMMAND",
    "FRUSTRATION_DETECTED",
}

# ── Fix 5: Fast greeting interceptor (0.05ms, no SLM) ────────────────────────
_GREETINGS = {
    "hi", "hello", "hey", "yo", "sup", "howdy", "what's up", "whats up",
    "hi there", "hello there", "hey there",
}
_GREETING_RESPONSES = [
    "Hey! Ready to help. What would you like to adjust?",
    "Hello! Climate, sunroof, headlights — what can I do for you?",
    "Hi there! All systems are online. What do you need?",
]
import random

def _is_greeting(text: str) -> bool:
    t = text.lower().strip().rstrip(".!?")
    return t in _GREETINGS


# ── Fix 10: Session analytics ─────────────────────────────────────────────────
_analytics = {
    "regex_hits":    0,
    "context_hits":  0,
    "rag_hits":      0,
    "slm_hits":      0,
    "macro_hits":    0,
    "chat_hits":     0,
    "failed":        0,
    "blocked":       0,
    "total":         0,
    "latency_sum":   0.0,
    "latency_count": 0,
}

def _record_analytics(intent: dict | None, failed: bool = False, blocked: bool = False) -> None:
    _analytics["total"] += 1
    if failed:  _analytics["failed"]  += 1; return
    if blocked: _analytics["blocked"] += 1; return
    if intent is None: return
    src = intent.get("handled_by", "").lower()
    if "regex"   in src: _analytics["regex_hits"]   += 1
    elif "context" in src: _analytics["context_hits"] += 1
    elif "rag"   in src: _analytics["rag_hits"]     += 1
    elif "llama" in src or "slm" in src: _analytics["slm_hits"] += 1
    elif "macro" in src: _analytics["macro_hits"]   += 1
    lat_str = intent.get("latency", "")
    try:
        lat_val = float(lat_str.replace("ms","").replace("s","").strip())
        if "ms" in lat_str: lat_val /= 1000
        _analytics["latency_sum"]   += lat_val
        _analytics["latency_count"] += 1
    except Exception:
        pass

def _print_analytics() -> None:
    t = _analytics["total"] or 1
    avg_lat = (_analytics["latency_sum"] / _analytics["latency_count"] * 1000
               if _analytics["latency_count"] else 0)
    print("\n" + "=" * 40)
    print("  SESSION ANALYTICS")
    print("=" * 40)
    print(f"  Total commands    : {_analytics['total']}")
    print(f"  Regex resolved    : {_analytics['regex_hits']}  ({_analytics['regex_hits']/t:.0%})")
    print(f"  Context resolved  : {_analytics['context_hits']}  ({_analytics['context_hits']/t:.0%})")
    print(f"  RAG resolved      : {_analytics['rag_hits']}  ({_analytics['rag_hits']/t:.0%})")
    print(f"  SLM resolved      : {_analytics['slm_hits']}  ({_analytics['slm_hits']/t:.0%})")
    print(f"  Macro hits        : {_analytics['macro_hits']}  ({_analytics['macro_hits']/t:.0%})")
    print(f"  Failed/Blocked    : {_analytics['failed'] + _analytics['blocked']}")
    print(f"  Avg latency       : {avg_lat:.1f} ms")
    print("=" * 40 + "\n")


# ── Fix 9: Dashboard state writer ────────────────────────────────────────────
_DASHBOARD_FILE = "/tmp/assistant_state.json"

def _update_dashboard(sm: StateManager, intent: dict | None, transcript: str,
                      response: str, confidence: float = 1.0) -> None:
    try:
        payload = {
            "transcript":  transcript,
            "response":    response,
            "confidence":  round(confidence * 100),
            "resolver":    intent.get("handled_by", "unknown") if intent else "none",
            "latency":     intent.get("latency", "0ms")        if intent else "0ms",
            "command":     intent.get("command", "")            if intent else "",
            "value":       intent.get("value",   "")            if intent else "",
            "vehicle_state": sm.get_state(),
            "analytics":   _analytics,
            "timestamp":   time.strftime("%H:%M:%S"),
        }
        with open(_DASHBOARD_FILE, "w") as f:
            json.dump(payload, f)
    except Exception:
        pass

# ── Fix 1: STT confidence gate threshold (module-level constant) ─────────────
# STT transcriptions below this confidence are not acted on — clarification asked instead
STT_CONFIDENCE_GATE = 0.45

# ── Display helpers ───────────────────────────────────────────────────────────

def _resolver_badge(src: str) -> str:
    """Return a clearly labelled resolver badge for terminal output."""
    s = src.lower()
    if "regex"   in s: return "[ REGEX ⚡]"
    if "context" in s: return "[ CONTEXT 🔁]"
    if "rag"     in s: return "[ RAG 📖]"
    if "llama"   in s or "slm" in s: return "[ SLM 🧠]"
    if "macro"   in s: return "[ MACRO 🎯]"
    if "context" in s: return "[ CONTEXT ]"
    return f"[ {src.upper()} ]"

def _conf_bar(conf: float | None) -> str:
    """Return a simple ASCII confidence bar."""
    if conf is None:
        return ""
    filled = int(conf * 10)
    bar = "█" * filled + "░" * (10 - filled)
    return f" [{bar}] {conf:.0%}"

def _print_intent(intent: dict) -> None:
    src   = intent.get("handled_by", "?")
    lat   = intent.get("latency",    "?")
    conf  = intent.get("confidence")
    cmd   = intent.get("command",    "")
    val   = intent.get("value",      "")
    badge = _resolver_badge(src)
    bar   = _conf_bar(conf)
    pri   = intent.get("priority", "")
    pri_str = f"  ⚠ {pri.upper()}" if pri else ""

    print(f"\n  ┌─ {badge}{bar}  ⏱ {lat}{pri_str}")
    if cmd and cmd not in ("RAG_RESPONSE", "STATUS_QUERY"):
        print(f"  │  Command : {cmd}  →  {val}")
    print(f"  └─ Reason  : {intent.get('reason', '')}")


def _say(msg: str) -> None:
    print(f'[Assistant] "{msg}"')
    if audio_sys:
        audio_sys.speak(msg)

# ── Confirmation message generator ────────────────────────────────────────────

_UNIT = {
    "SET_TEMPERATURE": "°C", "SET_FAN_SPEED": "", "SET_POSITION": "%",
    "SET_BRIGHTNESS": "%", "TOGGLE_AC": "", "SET_HEADLIGHTS": "",
}

_LABEL = {
    "SET_TEMPERATURE": "Temperature", "SET_FAN_SPEED": "Fan speed",
    "SET_POSITION": "Sunroof", "SET_BRIGHTNESS": "Brightness",
    "TOGGLE_AC": "AC", "SET_HEADLIGHTS": "Headlights",
}

def _confirm_message(intent: dict, was_no_change: bool, prev_value: int | None = None) -> str:
    cmd   = intent.get("command", "")
    val   = intent.get("value")
    label = _LABEL.get(cmd, cmd.replace("_", " ").title())
    unit  = _UNIT.get(cmd, "")

    if intent.get("_at_limit"):
        direction = "maximum" if (prev_value is not None and val >= prev_value) else "minimum"
        return f"{label} is already at its {direction} ({val}{unit})."
    if was_no_change:
        return f"{label} is already at {val}{unit} — no change."
    if cmd == "TOGGLE_AC":
        return "AC turned on." if val else "AC turned off."
    if cmd == "SET_HEADLIGHTS":
        return "Headlights turned on." if val else "Headlights turned off."
    if cmd == "SET_POSITION":
        if val == 0: return "Sunroof closed."
        if val == 100: return "Sunroof fully open."
        return f"Sunroof opened to {val}%."
    if intent.get("handled_by") == "ContextWindow" and prev_value is not None:
        if val > prev_value: return f"{label} increased to {val}{unit}."
        if val < prev_value: return f"{label} decreased to {val}{unit}."
        return f"{label} set to {val}{unit}."

    # Generic fallback — always returns a string (never None)
    if val is not None:
        return f"{label} set to {val}{unit}."
    return f"{label} updated."


# ── CAN dispatch ──────────────────────────────────────────────────────────────
async def _dispatch(bus: VirtualCANBus, intent: dict) -> None:
    await bus.publish(intent["can_id"], intent["command"], intent["value"])
    await asyncio.sleep(0.1)

# ── Per-clause resolver (stages 3–6) ─────────────────────────────────────────
def _resolve_clause(
    text: str, ctx_win: ContextWindow, ctx_res: ContextResolver,
    regex: RegexIntentResolver, rag, slm: SLMIntentResolver, slm_ok: bool,
    domain: str | None = None,
) -> dict | None:
    intent = ctx_win.resolve_relative(text, domain=domain)
    if intent: return intent

    intent = ctx_res.resolve(text)
    if intent: return intent

    intent = regex.resolve(text)
    if intent: return intent

    rag_triggers = ["manual", "guide", "search", "look up", "how to", "what is"]
    if any(trigger in text.lower() for trigger in rag_triggers):
        print("[System] RAG trigger detected. Searching knowledge base...")
        intent = rag.resolve(text)
        if intent: return intent

    if slm_ok:
        words = text.strip().split()
        if len(words) >= 2 and any(w.isalpha() for w in words):
            print("[System] Routing to SLM...")
            return slm.resolve(text)
        return None

# ── Intent execution ──────────────────────────────────────────────────────────
async def _execute_intent(
    clause: str, intent: dict, bus: VirtualCANBus, safety: SafetySupervisor,
    ctx_win: ContextWindow, dlg: DialogueManager, sm: StateManager,
    macro_eng: MacroEngine, show_clause: bool = False,
) -> None:
    if show_clause:
        print(f'\n[Clause] "{clause}"')

    _print_intent(intent)

    if "_wellness_msg" in intent: _say(intent["_wellness_msg"])
    if "_warning" in intent: print(f"[⚠ Warning] {intent['_warning']}")

    cmd = intent.get("command")

    if cmd == "INCOMPLETE_COMMAND":
        verb = intent.get("verb", "do")
        _say(f"{verb.capitalize()} what?")
        return
    if cmd == "SAFETY_ALERT":
        _say("I noticed a potential safety concern. Please check your vehicle.")
        return
    if cmd == "UNKNOWN":
        _say("I can only control vehicle systems. Try: temperature, sunroof, lights, or fan speed.")
        return
    if cmd == "STATUS_QUERY":
        # Fix 4: Status queries are SPOKEN via TTS, not just printed
        state = sm.get_state()
        ac_str = "on" if state.get("ac_enabled") else "off"
        hl_str = "on" if state.get("headlights") else "off"
        status_msg = (
            f"Cabin temperature is {state.get('ac_temperature', 22)} degrees. "
            f"Fan speed is {state.get('fan_speed', 2)} out of 5. "
            f"Air conditioning is {ac_str}. "
            f"Sunroof is {state.get('sunroof_position', 0)} percent open. "
            f"Headlights are {hl_str}. "
            f"Dashboard brightness is {state.get('brightness', 50)} percent."
        )
        print("\n[Vehicle State]")
        print(sm.snapshot())
        _say(status_msg)
        return
    if cmd == "MACRO_RESET":
        reset_macro = macro_eng.match("reset")
        if reset_macro:
            print(f"\n[Macro] {reset_macro['display']}")
            _say(reset_macro["speech"])
            await macro_eng.execute(bus, reset_macro)
        else:
            _say("Reset acknowledged — no reset macro defined.")
        return
    if cmd == "RAG_RESPONSE":
        answer = intent.get("answer", "")
        print("[RAG] Knowledge base lookup (latency=" + str(intent.get("latency","?")) + ")")
        if answer:
            flat  = answer.replace("\\n", " ").replace("\n", " ")
            parts = [s.strip() for s in flat.split(".") if len(s.strip()) > 8]
            spoken = ". ".join(parts[:2]) + "." if parts else flat
            disp = answer[:300] + "..." if len(answer) > 300 else answer
            print("[RAG] " + disp)
            _say(spoken)
        else:
            _say("I couldn't find that information.")
        return
    if cmd == "FRUSTRATION_DETECTED":
        # You can randomize these responses to make it feel more natural
        import random
        apologies = [
            "I'm really sorry, I know I can be frustrating sometimes. Let's try that again.",
            "My bad. I'm still learning. What did you want me to do?",
            "Sorry about that. I misheard you. Could you rephrase your command?",
            "I hear you. Let me reset my context. What can I help with?"
        ]
        _say(random.choice(apologies))
        
        # Optional: Clear the dialogue history so the AI gets a "fresh start"
        dlg.clear_pending()
        ctx_win.clear() 
        return

    pre_state = sm.get_state()

    # Fix 6: Post-SLM intent validator — block semantically inverted commands
    # Only applies to SLM-resolved intents (Regex/Regex are already verified)
    if intent.get("handled_by", "") in ("Llama-3.2-1B", "SLM"):
        is_valid, rejection_reason = validate_intent(clause, intent)
        if not is_valid:
            _say(rejection_reason)
            print(f"[Validator] Intent rejected: {rejection_reason}")
            return

    # Fix 8: Confirmation layer for risky commands
    if requires_confirmation(intent) and not intent.get("_confirmed"):
        prompt_msg = confirmation_prompt(intent)
        dlg.set_pending(intent)
        _say(prompt_msg)
        print(f"[Confirm] Awaiting confirmation for: {cmd}={intent.get('value')}")
        return

    allowed, warning = safety.check(intent)

    if warning: print(f"[Safety] {warning}")
    if not allowed:
        _say("I can't do that right now — it's been blocked for safety.")
        return

    cmd = intent.get("command", "")
    prev_val = sm.get_state().get(cmd)

    if intent.get("_at_limit"):
        _say(f"Already at the limit ({intent['value']}).")
    else:
        print(f"[CAN] {cmd} → {intent['can_id']} (value={intent['value']})")

    await _dispatch(bus, intent)

    post_state = sm.get_state()
    was_no_change = (pre_state == post_state) and not intent.get("_at_limit")

    confirm = _confirm_message(intent, was_no_change, prev_value=prev_val)
    _say(confirm)

    ctx_win.push(clause, intent)
    dlg.record(clause, intent, pre_state)

    nudge = ctx_win.check_proactive_nudge()
    if nudge: _say(nudge)

# ── Main loop ─────────────────────────────────────────────────────────────────
async def main() -> None:
    print("\nInitializing Edge AI Automotive Cockpit...")
    print("=" * 50)

    sm  = StateManager()
    bus = VirtualCANBus()
    ClimateModule(sm, bus)
    SunroofModule(sm, bus)
    LightingModule(sm, bus)

    macro_eng = MacroEngine()
    conv_lay  = ConversationLayer()
    ctx_win   = ContextWindow()
    ctx_res   = ContextResolver()
    regex_eng = RegexIntentResolver()
    rag_eng   = RAGResolver()
    slm_eng   = SLMIntentResolver()
    safety    = SafetySupervisor(sm)
    dlg       = DialogueManager()
    prefs     = PreferenceMemory()

    bus_task  = asyncio.create_task(bus.start())
    
    # Bypass health check to load instantly on Raspberry Pi
    slm_ready = True
    print("[System] Bypassing SLM health check. UI loading immediately.")

    print("\n" + "=" * 50)
    print(" VEHICLE SYSTEMS ONLINE                          ")
    print(" Macros  : dog mode | dog mode off | night mode   ")
    print("           morning mode | focus mode | bye | reset")
    print(" Memory  : 'remember this' | 'my usual settings' ")
    print(" Repair  : 'undo that' | 'go back' | 'never mind'")
    print(" Info    : 'help' | 'status'                     ")
    print(" Quit,bye    : 'exit'                                 ")
    print("=" * 50 + "\n")

    # ── Input Threading Setup ─────────────────────────────────────────────
    # We use a queue to safely accept both Voice and Keyboard input at the same time
    cmd_queue = queue.Queue()

    def keyboard_worker():
        while True:
            try:
                txt = input()
                if txt.strip():
                    # We echo the text explicitly so the log looks clean
                    print(f"\nDriver (Text): {txt.strip()}")
                    cmd_queue.put((txt.strip(), 1.0))
            except EOFError:
                break

    threading.Thread(target=keyboard_worker, daemon=True).start()

    # _processing_done: voice worker waits between commands
    _processing_done = threading.Event()
    _processing_done.set()  # starts ready

    if audio_sys:
        def voice_worker():
            while True:
                # Block until main loop finishes current command
                _processing_done.wait()
                # Block until TTS finishes (no feedback loop)
                audio_sys.wait_until_done_speaking(timeout=15)
                result = audio_sys.listen()
                # listen() returns (text, confidence) — unpack properly
                if isinstance(result, tuple):
                    txt, conf = result
                else:
                    txt, conf = str(result), 1.0
                # Only queue non-empty transcriptions
                if txt and txt.strip():
                    print(f"\nDriver (Voice): {txt}  [conf={conf:.0%}]")
                    _processing_done.clear()  # lock until processed
                    cmd_queue.put((txt.strip(), conf))
        threading.Thread(target=voice_worker, daemon=True).start()

    print("[System] Ready! You can TYPE in the terminal or SPEAK into the microphone.")

    async def _exec(clause: str, intent: dict, show_clause: bool = False) -> None:
        await _execute_intent(clause, intent, bus, safety, ctx_win, dlg, sm, macro_eng, show_clause=show_clause)

    while True:
        try:
            # Wait for either the voice mic or the keyboard to drop something in the queue
            item = await asyncio.to_thread(cmd_queue.get)
        except (EOFError, KeyboardInterrupt):
            break

        # Unpack (text, confidence) — keyboard always sends 1.0
        if isinstance(item, tuple):
            raw, stt_confidence = item
        else:
            raw, stt_confidence = item, 1.0

        if raw.lower() in ("exit", "quit", "bye", "goodbye"):
            break

        # ── Global Cancel / Stop ──
        # If the user says "cancel" or "stop", immediately stop any TTS and clear state
        if raw.lower() in ("cancel", "stop", "cancel that", "stop talking"):
            print("\n[System] Cancelled by user.")
            if audio_sys:
                audio_sys.stop_speaking()
            dlg.clear_pending()
            _update_dashboard(sm, None, raw, "Cancelled by user.", stt_confidence)
            _processing_done.set()
            continue

        # Fix 7: Fuzzy normalize BEFORE everything else
        raw_original = raw
        raw, was_fuzzy_corrected = fuzzy_normalize(raw)

        if is_gibberish(raw):
            _say("I didn't catch that — could you try again?")
            _record_analytics(None, failed=True)
            print("\n" + "-" * 50)
            _processing_done.set()
            continue

        # Fix 5: Fast greeting interceptor (0.05ms — NO SLM)
        if _is_greeting(raw):
            reply = random.choice(_GREETING_RESPONSES)
            _say(reply)
            _record_analytics(None)
            _update_dashboard(sm, None, raw, reply, stt_confidence)
            print("\n" + "-" * 50)
            _processing_done.set()
            continue

        # Fix 1: STT confidence gate — if STT wasn't confident, ask before acting
        if stt_confidence < STT_CONFIDENCE_GATE and not was_fuzzy_corrected:
            clarify_msg = "I'm not sure I heard you correctly. Could you please repeat the command?"
            _say(clarify_msg)
            print(f"[Confidence Gate] STT confidence {stt_confidence:.0%} < threshold. Asking for repetition.")
            _record_analytics(None, blocked=True)
            print("\n" + "-" * 50)
            _processing_done.set()
            continue

        # Fix 2: Inject current state + memory into SLM before any resolve attempt
        slm_eng.set_state_context(sm.get_state())
        slm_eng.set_memory_context(prefs._prefs if hasattr(prefs, '_prefs') else {})

        # ConversationLayer runs FIRST: catches greetings/help before anything else
        macro = macro_eng.match(raw)
        if macro:

            print(f"\n[Macro] {macro['display']}")
            _say(macro["speech"])
            await macro_eng.execute(bus, macro)
            await asyncio.sleep(0.1)
            print("\n" + "-" * 50)
            _processing_done.set()
            continue

        pref_action = prefs.detect(raw)
        if pref_action:
            state = sm.get_state()
            if pref_action == "query":
                print(f"\n{prefs.describe()}")
            elif pref_action == "save":
                msg = prefs.save_all(state)
                _say(msg)
            elif pref_action.startswith("save_key:"):
                key = pref_action.split(":", 1)[1]
                msg = prefs.save_key(key, state)
                _say(msg)
            elif pref_action == "load":
                actions = prefs.load_all()
                if actions:
                    _say("Restoring your saved preferences.")
                    for action in actions:
                        await bus.publish(action["can_id"], action["command"], action["value"])
                        await asyncio.sleep(0.12)
                else:
                    _say("No preferences saved yet. Say 'remember this' to save current settings.")
            print("\n" + "-" * 50)
            _processing_done.set()
            continue

        if dlg.is_repair(raw):
            action, undo_intent = dlg.resolve_repair(raw)
            if action == "cancel_pending":
                dlg.clear_pending()
                _say("Cancelled. What would you like to do instead?")
            elif action in ("undo", "undo_last") and undo_intent:
                _say("Reversing the last action.")
                pre_state = sm.get_state()
                allowed, warning = safety.check(undo_intent)
                if warning: print(f"[Safety] {warning}")
                if allowed:
                    print(f"[CAN] {undo_intent['command']} → {undo_intent['can_id']} (value={undo_intent['value']})")
                    await _dispatch(bus, undo_intent)
                    ctx_win.push(raw, undo_intent)
                    dlg.record(raw, undo_intent, pre_state)
                else:
                    print("[System] Undo blocked by safety supervisor.")
            elif action == "nothing_to_undo":
                _say("Nothing to undo — no recent action recorded.")
            else:
                intent = _resolve_clause(raw, ctx_win, ctx_res, regex_eng, rag_eng, slm_eng, slm_ready)
                if intent: await _exec(raw, intent)
                else: _say("I'm not sure what to adjust. Could you be more specific?")
            print("\n" + "-" * 50)
            _processing_done.set()
            continue

        if dlg.state == DialogueState.PENDING_CONFIRM:
            if dlg.is_confirmation(raw):
                pending = dlg.pop_pending()
                if pending:
                    _say("Confirmed.")
                    pending["_confirmed"] = True
                    await _exec(raw, pending)
            else:
                dlg.clear_pending()
                _say("Understood — action cancelled.")
            print("\n" + "-" * 50)
            _processing_done.set()
            continue

        reply = conv_lay.respond(raw)
        if reply:
            if reply == "_STATE_DUMP":
                print("\n[Vehicle State]")
                print(sm.snapshot())
            else:
                _say(reply)
            print("\n" + "-" * 50)
            _processing_done.set()
            continue

        clauses = split_intents(raw)
        domain_hint = dlg.extract_domain_hint(raw)
        resolved = []
        failed = []

        for clause in clauses:
            intent = _resolve_clause(clause, ctx_win, ctx_res, regex_eng, rag_eng, slm_eng, slm_ready, domain=domain_hint)
            if intent: resolved.append((clause, intent))
            else: failed.append(clause)

        resolved.sort(key=lambda ci: 0 if ci[1].get("priority") == "safety" else 1)

        if not resolved and not failed:
            print("\n[System] No command recognised.")
            _say("I didn't understand that — try saying something like 'set temperature to 22' or 'open sunroof'.")
            print("\n" + "-" * 50)
            _processing_done.set()
            continue

        for clause, intent in resolved:
            _record_analytics(intent)
            await _exec(clause, intent, show_clause=(len(clauses) > 1))
            _update_dashboard(sm, intent, raw, "Action executed.", stt_confidence)

        # For unresolved commands, try SLM natural chat as last resort
        if failed and not resolved:
            # Full sentence failed all resolvers — try SLM chat mode
            if slm_ready:
                print("[System] All resolvers failed — trying SLM chat...")
                chat_reply = slm_eng.chat(raw)
                if chat_reply:
                    _say(chat_reply)
                    _update_dashboard(sm, None, raw, chat_reply, stt_confidence)
                else:
                    msg = "I couldn't do that. Try 'help' for a list of commands."
                    _say(msg)
                    _update_dashboard(sm, None, raw, msg, stt_confidence)
            else:
                msg = "I couldn't do that. Try 'help' for a list of commands."
                _say(msg)
                _update_dashboard(sm, None, raw, msg, stt_confidence)
        elif failed:
            for clause in failed:
                print(f'\n[Clause] "{clause}" could not resolve.')
                msg = f"I couldn't process: {clause}. Please rephrase."
                _say(msg)
                _update_dashboard(sm, None, raw, msg, stt_confidence)

        print("\n" + "-" * 50)
        _processing_done.set()

    _print_analytics()
    print("\nShutting down vehicle systems...")
    bus_task.cancel()
    try: await bus_task
    except asyncio.CancelledError: pass
    print("Goodbye.")

if __name__ == "__main__":
    asyncio.run(main())      